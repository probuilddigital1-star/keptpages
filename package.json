{
  "name": "keptpages",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @keptpages/web dev",
    "dev:worker": "pnpm --filter @keptpages/worker dev",
    "build": "pnpm --filter @keptpages/web build",
    "build:worker": "pnpm --filter @keptpages/worker build",
    "preview": "pnpm --filter @keptpages/web preview",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18"
  }
}
